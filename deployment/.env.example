# Cafe Webapp Deployment Environment Variables
# Copy this file to .env and fill in your actual values

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/cafe_db
DB_USERNAME=cafe_user
DB_PASSWORD=your_secure_password

# JWT Secret
JWT_SECRET=your_jwt_secret_key_here

# Twilio Configuration (for SMS)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# Email Configuration
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password

# Railway Deployment (optional)
RAILWAY_TOKEN=your_railway_token

# AWS Configuration (optional, for AWS deployments)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1

# Docker Compose Environment
COMPOSE_PROJECT_NAME=cafe-webapp

# Kubernetes Namespace (optional)
K8S_NAMESPACE=cafe-production

# Domain Configuration
DOMAIN=api.cafe-webapp.com
ADMIN_DOMAIN=admin-api.cafe-webapp.com
