{
  "name": "cafe-webapp-mobile",
  "version": "1.0.0",
  "private": true,
  "description": "Capacitor wrapper for Cafe Web App (Android + iOS)",
  "scripts": {
    "sync:web": "node scripts/sync-web-assets.mjs",
    "cap:sync": "npm run sync:web && npx cap sync",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "android:sync": "npm run cap:sync",
    "android:bundle:release": "cd android && ./gradlew bundleRelease",
    "android:assemble:release": "cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^7.0.1",
    "@capacitor/core": "^7.0.1",
    "@capacitor/ios": "^7.0.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.1"
  }
}


