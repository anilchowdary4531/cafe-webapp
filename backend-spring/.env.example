PORT=4100
DATABASE_URL=jdbc:postgresql://localhost:5432/cafe_webapp
DB_USERNAME=postgres
DB_PASSWORD=postgres
# For production, include your hosted frontend origin and keep capacitor://localhost for mobile shells.
CORS_ORIGIN=http://localhost:8000,http://localhost,capacitor://localhost

# Do not keep demo OTP for production Play Store builds.
OTP_PROVIDER=demo
OTP_EXPIRY_SECONDS=300
OTP_RESEND_COOLDOWN_SECONDS=30
OTP_MAX_ATTEMPTS=5

# MSG91 (when OTP_PROVIDER=msg91)
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
MSG91_TEMPLATE_ID=
MSG91_ROUTE=4
MSG91_COUNTRY_CODE=91

# Firebase (when OTP_PROVIDER=firebase)
FIREBASE_SERVICE_ACCOUNT_PATH=

JWT_ISSUER=cafe-spring
JWT_SECRET=replace-with-a-very-long-random-secret-value-at-least-32-characters
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

ADMIN_ACCESS_EMAIL=anilchowdarya8@gmail.com
STAFF_ACCESS_EMAIL=staff@sunsetcafe.local



